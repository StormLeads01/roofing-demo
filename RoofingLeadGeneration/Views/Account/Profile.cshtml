@model RoofingLeadGeneration.Data.Models.User
@{
    Layout = null;
    var isAdmin = ViewBag.IsAdmin is true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Profile — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                navy:  { DEFAULT: '#0f172a', 700: '#1e293b', 600: '#334155', 500: '#475569' },
                brand: { DEFAULT: '#f97316', dark: '#ea6c0a', light: '#fdba74' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="min-h-screen">

@await Html.PartialAsync("_TrialBanner")

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-extrabold tracking-tight">Storm<span class="text-brand">Lead</span> Pro</span>
        </a>
        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">Search</a>
            <a href="/Leads/Saved" class="hover:text-white transition-colors">Saved Leads</a>
            <a href="/Dashboard" class="hover:text-white transition-colors">Dashboard</a>
            <a href="/Alerts" class="hover:text-white transition-colors">
                <i class="fa-solid fa-bell mr-1 text-xs"></i>Alerts
            </a>
            <a href="/Help" class="hover:text-white transition-colors">
                <i class="fa-solid fa-circle-question mr-1 text-xs"></i>Help
            </a>
            @if (isAdmin) {
                <a href="/Admin" class="text-orange-400 hover:text-orange-300 transition-colors">
                    <i class="fa-solid fa-shield-halved mr-1 text-xs"></i>Admin
                </a>
            }
            <span class="text-slate-600">|</span>
            @await Html.PartialAsync("_AccountMenu")
        </nav>

        <!-- Hamburger (mobile only) -->
        <button id="mobileMenuBtn" onclick="toggleMobileMenu()"
            class="lg:hidden p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-700/60 transition-colors">
            <i id="mobileMenuIcon" class="fa-solid fa-bars text-lg"></i>
        </button>
    </div>

    <!-- Mobile nav drawer -->
    <div id="mobileMenu" class="hidden lg:hidden absolute top-full left-0 right-0 bg-[#0f172a] border-t border-slate-700/60 shadow-2xl z-50 px-4 py-3 flex flex-col gap-1">
        <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-magnifying-glass w-4 text-center text-xs"></i>Search
        </a>
        <a href="/Leads/Saved" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-bookmark w-4 text-center text-xs"></i>Saved Leads
        </a>
        <a href="/Dashboard" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-chart-bar w-4 text-center text-xs"></i>Dashboard
        </a>
        <a href="/Alerts" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-bell w-4 text-center text-xs"></i>Alerts
        </a>
        <a href="/Help" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-300 hover:text-white hover:bg-slate-700/60 transition-colors text-sm">
            <i class="fa-solid fa-circle-question w-4 text-center text-xs"></i>Help
        </a>
        @if (isAdmin) {
            <a href="/Admin" class="flex items-center gap-3 px-3 py-3 rounded-xl text-orange-400 hover:text-orange-300 hover:bg-slate-700/60 transition-colors text-sm">
                <i class="fa-solid fa-shield-halved w-4 text-center text-xs"></i>Admin
            </a>
        }
        <div class="border-t border-slate-700/60 my-1"></div>
        @await Html.PartialAsync("_AccountMenuMobile")
    </div>
</header>

<!-- Page hero -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-2xl font-extrabold text-white">
            <i class="fa-solid fa-user text-brand mr-2"></i>My Profile
        </h1>
        <p class="text-slate-400 text-sm mt-0.5">Your personal name and contact info</p>
    </div>
</div>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 flex items-center gap-2 text-green-300 text-sm bg-green-400/10 border border-green-400/20 rounded-xl px-4 py-3">
            <i class="fa-solid fa-circle-check text-green-400"></i>
            <span>@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 flex items-center gap-2 text-red-300 text-sm bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3">
            <i class="fa-solid fa-triangle-exclamation text-red-400"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <form method="post" action="/Account/Profile">
        @Html.AntiForgeryToken()

        <div class="space-y-6">

            <!-- ── Your info ──────────────────────────────────────────── -->
            <div class="bg-slate-800/80 border border-slate-700/60 rounded-2xl p-6">
                <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">
                    <i class="fa-solid fa-id-card text-brand mr-2 text-xs"></i>Your Info
                </h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                    <div class="sm:col-span-2">
                        @Html.Label("displayName", "Name", new { @class = "block text-xs text-slate-400 mb-1.5" })
                        <input type="text" name="displayName" id="displayName"
                               value="@Model.DisplayName"
                               placeholder="Jane Smith"
                               required
                               class="w-full px-3 py-2.5 rounded-xl bg-slate-900 border border-slate-600 text-white text-sm placeholder-slate-500
                                      focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition" />
                    </div>

                    <div class="sm:col-span-2">
                        @Html.Label("email", "Login email", new { @class = "block text-xs text-slate-400 mb-1.5" })
                        <input type="email" id="email"
                               value="@Model.Email"
                               disabled
                               class="w-full px-3 py-2.5 rounded-xl bg-slate-900/60 border border-slate-700 text-slate-500 text-sm
                                      cursor-not-allowed" />
                        <p class="text-xs text-slate-500 mt-1.5">This is the email you sign in with and can't be changed here.</p>
                    </div>

                    <div>
                        @Html.Label("phone", "Phone number", new { @class = "block text-xs text-slate-400 mb-1.5" })
                        <input type="tel" name="phone" id="phone"
                               value="@Model.Phone"
                               placeholder="(555) 867-5309"
                               class="w-full px-3 py-2.5 rounded-xl bg-slate-900 border border-slate-600 text-white text-sm placeholder-slate-500
                                      focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition" />
                    </div>

                    <div>
                        @Html.Label("notificationEmail", "Notification email", new { @class = "block text-xs text-slate-400 mb-1.5" })
                        <input type="email" name="notificationEmail" id="notificationEmail"
                               value="@Model.NotificationEmail"
                               placeholder="alerts@example.com"
                               class="w-full px-3 py-2.5 rounded-xl bg-slate-900 border border-slate-600 text-white text-sm placeholder-slate-500
                                      focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition" />
                        <p class="text-xs text-slate-500 mt-1.5">Where storm/hail alerts are sent, if different from your login email.</p>
                    </div>

                </div>
            </div>

            <!-- ── Save button ───────────────────────────────────────── -->
            <div class="flex justify-end">
                <button type="submit"
                        class="flex items-center gap-2 px-6 py-3 rounded-xl bg-brand hover:bg-brand-dark
                               text-white font-bold text-sm tracking-wide shadow-lg shadow-brand/30
                               transition-all active:scale-95">
                    <i class="fa-solid fa-floppy-disk"></i>Save Profile
                </button>
            </div>

        </div>
    </form>
</div>

<!-- Footer -->
<footer class="mt-12 border-t border-slate-700/60 bg-slate-900/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500">
        <div class="flex items-center gap-2">
            <div class="w-5 h-5 bg-brand/80 rounded flex items-center justify-center">
                <i class="fa-solid fa-house-chimney text-white text-xs"></i>
            </div>
            <span>StormLead Pro &copy; 2026</span>
        </div>
        <a href="/Dashboard" class="text-brand hover:text-orange-300 transition-colors text-xs">Back to dashboard &rarr;</a>
    </div>
</footer>

<script>
function toggleMobileMenu() {
    var menu = document.getElementById('mobileMenu');
    var icon = document.getElementById('mobileMenuIcon');
    if (!menu) return;
    var nowHidden = menu.classList.toggle('hidden');
    icon.className = nowHidden ? 'fa-solid fa-bars text-lg' : 'fa-solid fa-xmark text-lg';
}
</script>
</body>
</html>
