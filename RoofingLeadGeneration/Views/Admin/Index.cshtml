@using RoofingLeadGeneration.Controllers
@{
    Layout = null;
    var totalUsers  = (int)(ViewBag.TotalUsers  ?? 0);
    var totalLeads  = (int)(ViewBag.TotalLeads  ?? 0);
    var enrichmentEnabled    = ViewBag.EnrichmentEnabled is true;
    var reportCreditsEnabled = ViewBag.ReportCreditsEnabled is true;
    var totalEnrich  = (int)(ViewBag.TotalEnrich ?? 0);
    var enrichMonth  = (int)(ViewBag.EnrichMonth ?? 0);
    var leadsMonth   = (int)(ViewBag.LeadsMonth  ?? 0);
    var reportsGenerated = (int)(ViewBag.ReportsGenerated ?? 0);
    var reportsMonth     = (int)(ViewBag.ReportsMonth     ?? 0);
    var users       = ViewBag.Users as List<AdminController.UserRow> ?? new();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                navy:  { DEFAULT: '#0f172a', 700: '#1e293b' },
                brand: { DEFAULT: '#f97316', dark: '#ea6c0a' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body class="min-h-screen">

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-extrabold tracking-tight">Storm<span class="text-brand">Lead</span> Pro</span>
        </a>
        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">Search</a>
            <a href="/Leads/Saved" class="hover:text-white transition-colors">Saved Leads</a>
            <a href="/Dashboard" class="hover:text-white transition-colors">Dashboard</a>
            <a href="/Admin" class="text-orange-400 font-semibold">
                <i class="fa-solid fa-shield-halved mr-1 text-xs"></i>Admin
            </a>
            <span class="text-slate-600">|</span>
            @await Html.PartialAsync("_AccountMenu")
        </nav>
    </div>
</header>

<!-- Page hero -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-2xl font-extrabold text-white">
            <i class="fa-solid fa-shield-halved text-brand mr-2"></i>Admin Dashboard
        </h1>
        <p class="text-slate-400 text-sm mt-0.5">Platform-wide metrics across all customers</p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    @if (TempData["AdminOk"] != null)
    {
        <div class="mb-6 rounded-xl border border-green-500/30 bg-green-500/10 text-green-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-circle-check mr-2"></i>@TempData["AdminOk"]
        </div>
    }
    @if (TempData["AdminError"] != null)
    {
        <div class="mb-6 rounded-xl border border-red-500/30 bg-red-500/10 text-red-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-triangle-exclamation mr-2"></i>@TempData["AdminError"]
        </div>
    }

    <!-- Platform stats -->
    <div class="grid grid-cols-2 lg:grid-cols-5 xl:grid-cols-7 gap-4 mb-8">
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Users</p>
            <p class="text-3xl font-extrabold text-white">@totalUsers</p>
            <p class="text-xs text-slate-500 mt-1">total registered</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Total Leads</p>
            <p class="text-3xl font-extrabold text-white">@totalLeads</p>
            <p class="text-xs text-slate-500 mt-1">across all users</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Leads / Month</p>
            <p class="text-3xl font-extrabold text-brand">@leadsMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
        @if (enrichmentEnabled)
        {
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Enrichments</p>
            <p class="text-3xl font-extrabold text-white">@totalEnrich</p>
            <p class="text-xs text-slate-500 mt-1">all time</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Enrich / Month</p>
            <p class="text-3xl font-extrabold text-brand">@enrichMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
        }
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Reports Generated</p>
            <p class="text-3xl font-extrabold text-white">@reportsGenerated</p>
            <p class="text-xs text-slate-500 mt-1">all time</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Reports / Month</p>
            <p class="text-3xl font-extrabold text-brand">@reportsMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
    </div>

    @if (!reportCreditsEnabled)
    {
        <div class="mb-6 rounded-xl border border-amber-500/30 bg-amber-500/10 text-amber-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-circle-info mr-2"></i>
            Report-credit gating is <strong>off</strong> (FeatureFlags:ReportCreditsEnabled = false) — PDF report
            generation is unlimited for everyone right now. Grants below still record balances so you can seed
            existing orgs before flipping the flag on. See docs/pricing-refresh-punchlist.md.
        </div>
    }

    <!-- Users table -->
    <div class="rounded-2xl border border-slate-700/60 overflow-hidden shadow-xl bg-slate-800/40">
        <div class="px-5 py-4 border-b border-slate-700/60">
            <h2 class="text-sm font-bold text-white">
                <i class="fa-solid fa-users text-brand mr-2"></i>All Users
                <span class="ml-2 text-xs font-normal text-slate-400">(@users.Count total)</span>
            </h2>
        </div>
        <div class="overflow-x-auto">
            <table id="usersTable" class="w-full border-collapse">
                <thead>
                    <tr>
                        <th class="text-left">User</th>
                        <th class="text-left">Leads</th>
                        @if (enrichmentEnabled) { <th class="text-left">Enrichments</th> }
                        <th class="text-left">PDFs Generated</th>
                        <th class="text-left">Last Lead</th>
                        <th class="text-left">Joined</th>
                        <th class="text-left">Plan / Trial</th>
                        <th class="text-left">Report Credits</th>
                        <th class="text-left">Manage Access</th>
                    </tr>
                </thead>
                <tbody>
                    @if (users.Any())
                    {
                        @foreach (var u in users)
                        {
                            var joined = u.CreatedAt.ToString("yyyy-MM-dd");
                            var lastLead = u.LastLeadAt.HasValue ? u.LastLeadAt.Value.ToString("yyyy-MM-dd") : "—";
                            var planLabel = string.IsNullOrEmpty(u.Plan) ? "—" : u.Plan;
                            string trialText;
                            string trialCls;
                            if (u.OrgId == null)
                            {
                                trialText = "no org";
                                trialCls  = "text-slate-500";
                            }
                            else if (u.TrialEndsAt == null)
                            {
                                trialText = "Unlimited";
                                trialCls  = "text-green-400";
                            }
                            else if (u.TrialEndsAt.Value < DateTime.UtcNow)
                            {
                                trialText = "Expired";
                                trialCls  = "text-red-400";
                            }
                            else
                            {
                                var d = (int)Math.Ceiling((u.TrialEndsAt.Value - DateTime.UtcNow).TotalDays);
                                trialText = d + " day" + (d == 1 ? "" : "s") + " left";
                                trialCls  = "text-slate-300";
                            }
                            <tr>
                                <td>
                                    <p class="font-semibold text-white text-xs">@(string.IsNullOrEmpty(u.DisplayName) ? "—" : u.DisplayName)</p>
                                    <p class="text-slate-500 text-xs">@u.Email</p>
                                </td>
                                <td class="font-semibold text-white">@u.LeadCount</td>
                                @if (enrichmentEnabled) { <td class="font-semibold text-white">@u.EnrichCount</td> }
                                <td class="font-semibold text-white">@u.PdfCount</td>
                                <td class="text-slate-400 whitespace-nowrap">@lastLead</td>
                                <td class="text-slate-400 whitespace-nowrap">@joined</td>
                                <td class="whitespace-nowrap">
                                    <span class="px-2 py-0.5 rounded-full bg-slate-500/20 text-slate-300 border border-slate-600 text-xs">@planLabel</span>
                                    <span class="ml-1.5 text-xs @trialCls">@trialText</span>
                                </td>
                                <td class="whitespace-nowrap">
                                    @if (u.OrgId != null)
                                    {
                                        <div class="flex flex-col gap-1.5">
                                            <p class="text-sm font-bold text-white">@u.ReportCredits <span class="text-xs font-normal text-slate-500">credits</span></p>
                                            <form method="post" action="/Admin/Users/@u.Id/ReportCredits" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="op" value="grant" />
                                                <select name="source" class="bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1">
                                                    <option value="subscription">monthly (plan)</option>
                                                    <option value="purchase_topup">top-up (+3)</option>
                                                    <option value="purchase_pack50">50-pack</option>
                                                    <option value="purchase_pack100">100-pack</option>
                                                    <option value="admin_grant">manual amount</option>
                                                </select>
                                                <input type="number" name="amount" value="1" min="1" title="Only used for 'manual amount'"
                                                       class="w-12 bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1" />
                                                <button type="submit" class="px-2 py-1 rounded bg-brand hover:bg-brand-dark text-white text-xs">Grant</button>
                                            </form>
                                            <form method="post" action="/Admin/Users/@u.Id/ReportCredits" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="op" value="forfeit" />
                                                <button type="submit" class="px-2 py-1 rounded bg-red-600/80 hover:bg-red-600 text-white text-xs"
                                                        title="Zeroes banked subscription rollover only — purchased credits (top-up/packs) are never forfeited">
                                                    Forfeit rollover
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-600 text-xs">—</span>
                                    }
                                </td>
                                <td class="whitespace-nowrap">
                                    @if (u.OrgId != null)
                                    {
                                        <div class="flex flex-col gap-1.5">
                                            <form method="post" action="/Admin/Users/@u.Id/Plan" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <select name="plan" class="bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1">
                                                    <option value="trial" selected="@(u.Plan == "trial" ? "selected" : null)">trial (14-day, 1 report)</option>
                                                    <option value="starter" selected="@(u.Plan == "starter" ? "selected" : null)">starter ($9.99, 10/mo)</option>
                                                    <option value="pro" selected="@(u.Plan == "pro" ? "selected" : null)">pro ($29.99, 75/mo)</option>
                                                    <option value="free" selected="@(u.Plan == "free" ? "selected" : null)">free (legacy)</option>
                                                    <option value="agency" selected="@(u.Plan == "agency" ? "selected" : null)">agency (legacy)</option>
                                                </select>
                                                <button type="submit" class="px-2 py-1 rounded bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs">Set plan</button>
                                            </form>
                                            <form method="post" action="/Admin/Users/@u.Id/Trial" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="number" name="days" value="14" min="0" class="w-14 bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1" />
                                                <button type="submit" name="op" value="set" class="px-2 py-1 rounded bg-brand hover:bg-brand-dark text-white text-xs">Set</button>
                                                <button type="submit" name="op" value="extend" class="px-2 py-1 rounded bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs">+Extend</button>
                                                <button type="submit" name="op" value="unlimited" class="px-2 py-1 rounded bg-green-600/80 hover:bg-green-600 text-white text-xs" title="Never gated">&#8734;</button>
                                                <button type="submit" name="op" value="expire" class="px-2 py-1 rounded bg-red-600/80 hover:bg-red-600 text-white text-xs">Expire</button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-600 text-xs">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-slate-500 py-10 text-sm">
                                <i class="fa-solid fa-users text-3xl text-slate-700 block mb-2"></i>
                                No users yet
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>