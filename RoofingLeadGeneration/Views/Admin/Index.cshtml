@using RoofingLeadGeneration.Controllers
@{
    Layout = null;
    var totalUsers  = (int)(ViewBag.TotalUsers  ?? 0);
    var totalLeads  = (int)(ViewBag.TotalLeads  ?? 0);
    var enrichmentEnabled    = ViewBag.EnrichmentEnabled is true;
    var reportCreditsEnabled = ViewBag.ReportCreditsEnabled is true;
    var isSuperAdmin         = ViewBag.IsSuperAdmin is true;
    var totalEnrich  = (int)(ViewBag.TotalEnrich ?? 0);
    var enrichMonth  = (int)(ViewBag.EnrichMonth ?? 0);
    var leadsMonth   = (int)(ViewBag.LeadsMonth  ?? 0);
    var reportsGenerated = (int)(ViewBag.ReportsGenerated ?? 0);
    var reportsMonth     = (int)(ViewBag.ReportsMonth     ?? 0);
    var users       = ViewBag.Users as List<AdminController.UserRow> ?? new();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                navy:  { DEFAULT: '#0f172a', 700: '#1e293b' },
                brand: { DEFAULT: '#f97316', dark: '#ea6c0a' }
            }}}
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body class="min-h-screen">

<!-- Header -->
<header class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-700/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
            <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center shadow">
                <i class="fa-solid fa-house-chimney text-white text-sm"></i>
            </div>
            <span class="text-lg font-extrabold tracking-tight">Storm<span class="text-brand">Lead</span> Pro</span>
        </a>
        <nav class="hidden lg:flex items-center gap-6 text-sm text-slate-400">
            <a href="/" class="hover:text-white transition-colors">Search</a>
            <a href="/Leads/Saved" class="hover:text-white transition-colors">Saved Leads</a>
            <a href="/Dashboard" class="hover:text-white transition-colors">Dashboard</a>
            <a href="/Admin" class="text-orange-400 font-semibold">
                <i class="fa-solid fa-shield-halved mr-1 text-xs"></i>Admin
            </a>
            <span class="text-slate-600">|</span>
            @await Html.PartialAsync("_AccountMenu")
        </nav>
    </div>
</header>

<!-- Page hero -->
<div class="border-b border-slate-700/40 bg-gradient-to-r from-slate-900 to-[#0f172a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <h1 class="text-2xl font-extrabold text-white">
            <i class="fa-solid fa-shield-halved text-brand mr-2"></i>Admin Dashboard
        </h1>
        <p class="text-slate-400 text-sm mt-0.5">Platform-wide metrics across all customers</p>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    @if (TempData["AdminOk"] != null)
    {
        <div class="mb-6 rounded-xl border border-green-500/30 bg-green-500/10 text-green-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-circle-check mr-2"></i>@TempData["AdminOk"]
        </div>
    }
    @if (TempData["AdminError"] != null)
    {
        <div class="mb-6 rounded-xl border border-red-500/30 bg-red-500/10 text-red-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-triangle-exclamation mr-2"></i>@TempData["AdminError"]
        </div>
    }

    <!-- Platform stats -->
    <div class="grid grid-cols-2 lg:grid-cols-5 xl:grid-cols-7 gap-4 mb-8">
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Users</p>
            <p class="text-3xl font-extrabold text-white">@totalUsers</p>
            <p class="text-xs text-slate-500 mt-1">total registered</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Total Leads</p>
            <p class="text-3xl font-extrabold text-white">@totalLeads</p>
            <p class="text-xs text-slate-500 mt-1">across all users</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Leads / Month</p>
            <p class="text-3xl font-extrabold text-brand">@leadsMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
        @if (enrichmentEnabled)
        {
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Enrichments</p>
            <p class="text-3xl font-extrabold text-white">@totalEnrich</p>
            <p class="text-xs text-slate-500 mt-1">all time</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Enrich / Month</p>
            <p class="text-3xl font-extrabold text-brand">@enrichMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
        }
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Reports Generated</p>
            <p class="text-3xl font-extrabold text-white">@reportsGenerated</p>
            <p class="text-xs text-slate-500 mt-1">all time</p>
        </div>
        <div class="stat-card">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2">Reports / Month</p>
            <p class="text-3xl font-extrabold text-brand">@reportsMonth</p>
            <p class="text-xs text-slate-500 mt-1">current month</p>
        </div>
    </div>

    @if (!reportCreditsEnabled)
    {
        <div class="mb-6 rounded-xl border border-amber-500/30 bg-amber-500/10 text-amber-300 px-4 py-3 text-sm">
            <i class="fa-solid fa-circle-info mr-2"></i>
            Report-credit gating is <strong>off</strong> (FeatureFlags:ReportCreditsEnabled = false) — PDF report
            generation is unlimited for everyone right now. Grants below still record balances so you can seed
            existing orgs before flipping the flag on. See docs/pricing-refresh-punchlist.md.
        </div>
    }

    <!-- Users table -->
    <div class="rounded-2xl border border-slate-700/60 overflow-hidden shadow-xl bg-slate-800/40">
        <div class="px-5 py-4 border-b border-slate-700/60 flex items-center justify-between">
            <h2 class="text-sm font-bold text-white">
                <i class="fa-solid fa-users text-brand mr-2"></i>All Users
                <span class="ml-2 text-xs font-normal text-slate-400">(@users.Count total)</span>
            </h2>
            @{
                var emailableCount = users.Count(u => !string.IsNullOrEmpty(u.Email));
            }
            @if (emailableCount > 0)
            {
                <button type="button" onclick="openBroadcastEmailModal(@emailableCount)"
                        class="px-3 py-1.5 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs font-semibold">
                    <i class="fa-solid fa-bullhorn mr-1.5 text-brand"></i>Email All
                </button>
            }
        </div>
        <div class="overflow-x-auto">
            <table id="usersTable" class="w-full border-collapse">
                <thead>
                    <tr>
                        <th class="text-left">User</th>
                        <th class="text-left">Leads</th>
                        @if (enrichmentEnabled) { <th class="text-left">Enrichments</th> }
                        <th class="text-left">PDFs Generated</th>
                        <th class="text-left">Last Lead</th>
                        <th class="text-left">Joined</th>
                        <th class="text-left">Plan / Trial</th>
                        <th class="text-left">Report Credits</th>
                        <th class="text-left">Manage Access</th>
                    </tr>
                </thead>
                <tbody>
                    @if (users.Any())
                    {
                        @foreach (var u in users)
                        {
                            var joined = u.CreatedAt.ToString("yyyy-MM-dd");
                            var lastLead = u.LastLeadAt.HasValue ? u.LastLeadAt.Value.ToString("yyyy-MM-dd") : "—";
                            var planLabel = string.IsNullOrEmpty(u.Plan) ? "—" : u.Plan;
                            var trialEndsIso = u.TrialEndsAt.HasValue ? u.TrialEndsAt.Value.ToString("o") : "";
                            string trialText;
                            string trialCls;
                            if (u.OrgId == null)
                            {
                                trialText = "no org";
                                trialCls  = "text-slate-500";
                            }
                            else if (u.TrialEndsAt == null)
                            {
                                trialText = "Unlimited";
                                trialCls  = "text-green-400";
                            }
                            else if (u.TrialEndsAt.Value < DateTime.UtcNow)
                            {
                                trialText = "Expired";
                                trialCls  = "text-red-400";
                            }
                            else
                            {
                                var d = (int)Math.Ceiling((u.TrialEndsAt.Value - DateTime.UtcNow).TotalDays);
                                trialText = d + " day" + (d == 1 ? "" : "s") + " left";
                                trialCls  = "text-slate-300";
                            }
                            <tr>
                                <td>
                                    <div class="flex items-start gap-2">
                                        <div>
                                            <p class="font-semibold text-white text-xs">
                                                @(string.IsNullOrEmpty(u.DisplayName) ? "—" : u.DisplayName)
                                                @if (u.Role == "super_admin")
                                                {
                                                    <span class="ml-1 px-1.5 py-0.5 rounded bg-brand/20 text-brand text-[10px] font-bold uppercase tracking-wide">Super Admin</span>
                                                }
                                                else if (u.Role == "admin")
                                                {
                                                    <span class="ml-1 px-1.5 py-0.5 rounded bg-blue-500/20 text-blue-300 text-[10px] font-bold uppercase tracking-wide">Admin</span>
                                                }
                                            </p>
                                            <p class="text-slate-500 text-xs">@u.Email</p>
                                        </div>
                                        @if (!string.IsNullOrEmpty(u.Email))
                                        {
                                            <button type="button" onclick="openEmailModal(this)"
                                                    data-id="@u.Id" data-email="@u.Email" data-name="@u.DisplayName"
                                                    class="mt-0.5 text-slate-500 hover:text-brand transition-colors shrink-0" title="Email this user">
                                                <i class="fa-solid fa-envelope text-xs"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td class="font-semibold text-white">@u.LeadCount</td>
                                @if (enrichmentEnabled) { <td class="font-semibold text-white">@u.EnrichCount</td> }
                                <td class="font-semibold text-white">@u.PdfCount</td>
                                <td class="text-slate-400 whitespace-nowrap">@lastLead</td>
                                <td class="text-slate-400 whitespace-nowrap">@joined</td>
                                <td class="whitespace-nowrap">
                                    <span class="px-2 py-0.5 rounded-full bg-slate-500/20 text-slate-300 border border-slate-600 text-xs">@planLabel</span>
                                    <span class="ml-1.5 text-xs @trialCls">@trialText</span>
                                </td>
                                <td class="whitespace-nowrap">
                                    @if (u.OrgId != null)
                                    {
                                        <div class="flex flex-col gap-1.5">
                                            <p class="text-sm font-bold text-white">@u.ReportCredits <span class="text-xs font-normal text-slate-500">credits</span></p>
                                            <form method="post" action="/Admin/Users/@u.Id/ReportCredits" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="op" value="grant" />
                                                <select name="source" class="bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1">
                                                    <option value="subscription">monthly (plan)</option>
                                                    <option value="purchase_topup">top-up (+3)</option>
                                                    <option value="purchase_pack50">50-pack</option>
                                                    <option value="purchase_pack100">100-pack</option>
                                                    <option value="admin_grant">manual amount</option>
                                                </select>
                                                <input type="number" name="amount" value="1" min="1" title="Only used for 'manual amount'"
                                                       class="w-12 bg-slate-900 border border-slate-600 rounded text-xs text-white px-1.5 py-1" />
                                                <button type="submit" class="px-2 py-1 rounded bg-brand hover:bg-brand-dark text-white text-xs">Grant</button>
                                            </form>
                                            <form method="post" action="/Admin/Users/@u.Id/ReportCredits" class="flex items-center gap-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="op" value="forfeit" />
                                                <button type="submit" class="px-2 py-1 rounded bg-red-600/80 hover:bg-red-600 text-white text-xs"
                                                        title="Zeroes banked subscription rollover only — purchased credits (top-up/packs) are never forfeited">
                                                    Forfeit rollover
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-600 text-xs">—</span>
                                    }
                                </td>
                                <td class="whitespace-nowrap">
                                    @if (u.OrgId != null)
                                    {
                                        <button type="button" onclick="openAccessModal(this)"
                                                data-id="@u.Id" data-plan="@u.Plan"
                                                data-trial-ends="@trialEndsIso" data-role="@u.Role"
                                                class="px-2.5 py-1.5 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs font-semibold">
                                            <i class="fa-solid fa-sliders mr-1"></i>Manage
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-slate-600 text-xs">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-slate-500 py-10 text-sm">
                                <i class="fa-solid fa-users text-3xl text-slate-700 block mb-2"></i>
                                No users yet
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Manage access modal -->
<div id="accessModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4" style="background: rgba(0,0,0,0.6);">
    <div class="bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl w-full max-w-md">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-700">
            <h3 class="text-white font-bold text-sm">
                <i class="fa-solid fa-sliders text-brand mr-2"></i>Manage Access
            </h3>
            <button type="button" onclick="closeAccessModal()" class="text-slate-500 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="p-5 space-y-5">
            <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Plan</p>
                <form id="accessPlanForm" method="post" class="flex items-center gap-2">
                    @Html.AntiForgeryToken()
                    <select id="accessPlanSelect" name="plan"
                            class="flex-1 bg-slate-900 border border-slate-600 rounded-lg text-sm text-white px-3 py-2 focus:outline-none focus:border-brand">
                        <option value="trial">trial (14-day, 1 report)</option>
                        <option value="starter">starter ($9.99, 10/mo)</option>
                        <option value="pro">pro ($29.99, 75/mo)</option>
                        <option value="free">free (legacy)</option>
                        <option value="agency">agency (legacy)</option>
                    </select>
                    <button type="submit" class="px-3 py-2 rounded-lg bg-brand hover:bg-brand-dark text-white text-xs font-semibold">Set</button>
                </form>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Trial</p>
                <p id="accessTrialStatus" class="text-xs text-slate-400 mb-2"></p>
                <form id="accessTrialForm" method="post" class="flex flex-wrap items-center gap-1.5">
                    @Html.AntiForgeryToken()
                    <input type="number" name="days" value="14" min="0"
                           class="w-16 bg-slate-900 border border-slate-600 rounded-lg text-xs text-white px-2 py-1.5" />
                    <button type="submit" name="op" value="set" class="px-2.5 py-1.5 rounded-lg bg-brand hover:bg-brand-dark text-white text-xs">Set</button>
                    <button type="submit" name="op" value="extend" class="px-2.5 py-1.5 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs">+Extend</button>
                    <button type="submit" name="op" value="unlimited" class="px-2.5 py-1.5 rounded-lg bg-green-600/80 hover:bg-green-600 text-white text-xs" title="Never gated">&#8734; Unlimited</button>
                    <button type="submit" name="op" value="expire" class="px-2.5 py-1.5 rounded-lg bg-red-600/80 hover:bg-red-600 text-white text-xs">Expire</button>
                </form>
            </div>
            @if (isSuperAdmin)
            {
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Admin role</p>
                    <p id="accessRoleStatus" class="text-xs text-slate-400 mb-2"></p>
                    <form id="accessRoleForm" method="post" class="flex items-center gap-1.5">
                        @Html.AntiForgeryToken()
                        <button type="submit" name="role" value="admin" class="px-2.5 py-1.5 rounded-lg bg-blue-600/80 hover:bg-blue-600 text-white text-xs">Make admin</button>
                        <button type="submit" name="role" value="user" class="px-2.5 py-1.5 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs">Remove admin</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

<!-- Email user modal -->
<div id="emailModal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4" style="background: rgba(0,0,0,0.6);">
    <div class="bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl w-full max-w-lg">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-700">
            <h3 class="text-white font-bold text-sm">
                <i class="fa-solid fa-envelope text-brand mr-2"></i>Email <span id="emailModalName" class="text-slate-400 font-normal"></span>
            </h3>
            <button type="button" onclick="closeEmailModal()" class="text-slate-500 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <form id="emailModalForm" method="post" class="p-5 space-y-3">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-xs text-slate-400 mb-1">Template</label>
                <select id="emailTemplateSelect" onchange="applyEmailTemplate()"
                        class="w-full bg-slate-900 border border-slate-600 rounded-lg text-sm text-white px-3 py-2 focus:outline-none focus:border-brand">
                    <option value="blank">Custom (blank)</option>
                    <option value="feature_invite">Invite: try new features + feedback</option>
                    <option value="checkin">Check-in / re-engagement</option>
                </select>
            </div>
            <div>
                <label class="block text-xs text-slate-400 mb-1">To</label>
                <input id="emailModalTo" type="text" disabled
                       class="w-full bg-slate-900/60 border border-slate-700 rounded-lg text-sm text-slate-400 px-3 py-2" />
            </div>
            <div>
                <label class="block text-xs text-slate-400 mb-1">Subject</label>
                <input id="emailSubject" name="subject" type="text" required
                       class="w-full bg-slate-900 border border-slate-600 rounded-lg text-sm text-white px-3 py-2 focus:outline-none focus:border-brand" />
            </div>
            <div>
                <label class="block text-xs text-slate-400 mb-1">Message</label>
                <textarea id="emailBody" name="body" rows="9" required
                          class="w-full bg-slate-900 border border-slate-600 rounded-lg text-sm text-white px-3 py-2 focus:outline-none focus:border-brand"></textarea>
                <p class="text-xs text-slate-500 mt-1">Feel free to edit the template text before sending.</p>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeEmailModal()" class="px-3 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs">Cancel</button>
                <button type="submit" class="px-4 py-2 rounded-lg bg-brand hover:bg-brand-dark text-white text-xs font-semibold">
                    <i class="fa-solid fa-paper-plane mr-1"></i>Send
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    var emailTemplates = {
        blank: { subject: '', body: '' },
        feature_invite: {
            subject: "You're invited — try what's new on StormLead Pro",
            body: "Hi {{name}},\n\nWe've been rolling out some new features on StormLead Pro — an interactive Storm Explorer map (click an address or draw an area to pull real hail history straight into your leads list), self-serve plan upgrades, and a few other improvements.\n\nWould you be up for trying a few of these out and sharing any feedback? Good or bad, it all helps us make the product better.\n\nJust reply to this email whenever you get a chance.\n\nThanks,\nThe StormLead Pro team"
        },
        checkin: {
            subject: "Checking in from StormLead Pro",
            body: "Hi {{name}},\n\nJust wanted to check in and see how things are going with StormLead Pro. Let us know if there's anything we can help with, or if you've run into any issues.\n\nThanks,\nThe StormLead Pro team"
        }
    };

    function openEmailModal(btn) {
        var id    = btn.dataset.id;
        var email = btn.dataset.email;
        var name  = btn.dataset.name;

        var form = document.getElementById('emailModalForm');
        form.action = '/Admin/Users/' + id + '/Email';
        form.dataset.name = name || (email ? email.split('@@')[0] : 'there');

        document.getElementById('emailModalTo').value = email || '';
        document.getElementById('emailModalName').textContent = '— ' + (name || email || '');
        document.getElementById('emailTemplateSelect').value = 'blank';
        applyEmailTemplate();

        document.getElementById('emailModal').classList.remove('hidden');
    }

    function openBroadcastEmailModal(count) {
        var form = document.getElementById('emailModalForm');
        form.action = '/Admin/EmailAll';
        form.dataset.name = 'there';

        document.getElementById('emailModalTo').value = 'All users (' + count + ' recipient' + (count === 1 ? '' : 's') + ', sent via BCC)';
        document.getElementById('emailModalName').textContent = '— All Users';
        document.getElementById('emailTemplateSelect').value = 'blank';
        applyEmailTemplate();

        document.getElementById('emailModal').classList.remove('hidden');
    }

    function closeEmailModal() {
        document.getElementById('emailModal').classList.add('hidden');
    }

    function applyEmailTemplate() {
        var key  = document.getElementById('emailTemplateSelect').value;
        var tpl  = emailTemplates[key] || emailTemplates.blank;
        var name = document.getElementById('emailModalForm').dataset.name || 'there';

        document.getElementById('emailSubject').value = tpl.subject;
        document.getElementById('emailBody').value = tpl.body.replace(/\{\{name\}\}/g, name);
    }

    document.getElementById('emailModal').addEventListener('click', function (e) {
        if (e.target === this) closeEmailModal();
    });

    function openAccessModal(btn) {
        var id        = btn.dataset.id;
        var plan      = btn.dataset.plan;
        var trialEnds = btn.dataset.trialEnds;
        var role      = btn.dataset.role;

        document.getElementById('accessPlanForm').action  = '/Admin/Users/' + id + '/Plan';
        document.getElementById('accessTrialForm').action = '/Admin/Users/' + id + '/Trial';
        document.getElementById('accessPlanSelect').value = plan || 'trial';

        var statusEl = document.getElementById('accessTrialStatus');
        if (!trialEnds) {
            statusEl.textContent = 'Currently: unlimited (never gated)';
        } else {
            var d = new Date(trialEnds);
            statusEl.textContent = (d.getTime() < Date.now())
                ? 'Currently: expired (' + d.toLocaleDateString() + ')'
                : 'Currently: ends ' + d.toLocaleDateString();
        }

        var roleForm = document.getElementById('accessRoleForm');
        if (roleForm) {
            roleForm.action = '/Admin/Users/' + id + '/Role';
            var roleStatusEl = document.getElementById('accessRoleStatus');
            var isSuper = role === 'super_admin';
            roleStatusEl.textContent = isSuper
                ? 'Currently: super admin (managed via login, not here)'
                : 'Currently: ' + (role === 'admin' ? 'admin' : 'regular user');
            var roleButtons = roleForm.querySelectorAll('button');
            roleButtons.forEach(function (b) { b.disabled = isSuper; b.classList.toggle('opacity-40', isSuper); });
        }

        document.getElementById('accessModal').classList.remove('hidden');
    }

    function closeAccessModal() {
        document.getElementById('accessModal').classList.add('hidden');
    }

    document.getElementById('accessModal').addEventListener('click', function (e) {
        if (e.target === this) closeAccessModal();
    });
</script>

</body>
</html>