@{
    Layout = null;
    var returnUrl      = ViewData["ReturnUrl"]      as string ?? "/";
    var registerError  = ViewData["RegisterError"]  as string;
    var companyName    = ViewData["CompanyName"]    as string;
    var name           = ViewData["Name"]           as string;
    var email          = ViewData["Email"]          as string;
    var selectedPlan   = ViewData["Plan"]            as string ?? "trial";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create your account — StormLead Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body class="min-h-screen flex items-center justify-center p-4">

<div class="w-full max-w-md">

    <!-- Logo -->
    <div class="text-center mb-8">
        <div class="inline-flex items-center gap-2.5 mb-4">
            <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center shadow-lg">
                <i class="fa-solid fa-house-chimney text-white"></i>
            </div>
            <span class="text-2xl font-extrabold text-white tracking-tight">
                Storm<span class="text-orange-500">Lead</span> Pro
            </span>
        </div>
        <p class="text-slate-400 text-sm">Start finding storm-damaged roofs in your area</p>
    </div>

    <!-- Card -->
    <div class="bg-slate-800/80 border border-slate-700/60 rounded-2xl p-8 shadow-2xl">

        <h2 class="text-white font-bold text-lg mb-6 text-center">Create your account</h2>

        @if (registerError != null)
        {
            <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-4 py-3 text-red-400 text-sm text-center mb-4">
                <i class="fa-solid fa-circle-exclamation mr-1"></i>@registerError
            </div>
        }

        <form method="post" action="/Auth/Register?returnUrl=@Uri.EscapeDataString(returnUrl)" class="space-y-3">

            <!-- Account type — required. Everyone starts on the same 14-day
                 trial regardless of plan picked here; Starter/Pro just
                 records intent (and emails the admin) so support can follow
                 up if needed. Real self-serve upgrade happens later via
                 embedded Stripe Checkout at /Billing/Upgrade — see
                 BillingController + Views/Billing/Upgrade.cshtml. -->
            <div class="space-y-2 mb-4">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Choose an account type</p>

                <label class="flex items-start gap-3 border-2 rounded-xl px-4 py-3 cursor-pointer transition-colors
                               has-[:checked]:border-orange-500 has-[:checked]:bg-orange-500/10 border-slate-700 bg-slate-900/40">
                    <input type="radio" name="plan" value="trial" required class="mt-1 accent-orange-500"
                           checked="@(selectedPlan == "trial" ? "checked" : null)" />
                    <span class="flex-1">
                        <span class="flex items-baseline justify-between">
                            <span class="text-white text-sm font-semibold">Free Trial</span>
                            <span class="text-slate-400 text-xs">$0 / 14 days</span>
                        </span>
                        <span class="block text-slate-500 text-xs mt-0.5">1 PDF hail report, full access, no card required</span>
                    </span>
                </label>

                <label class="flex items-start gap-3 border-2 rounded-xl px-4 py-3 cursor-pointer transition-colors
                               has-[:checked]:border-orange-500 has-[:checked]:bg-orange-500/10 border-slate-700 bg-slate-900/40">
                    <input type="radio" name="plan" value="starter" required class="mt-1 accent-orange-500"
                           checked="@(selectedPlan == "starter" ? "checked" : null)" />
                    <span class="flex-1">
                        <span class="flex items-baseline justify-between">
                            <span class="text-white text-sm font-semibold">Starter</span>
                            <span class="text-slate-400 text-xs">$9.99 / month</span>
                        </span>
                        <span class="block text-slate-500 text-xs mt-0.5">10 PDF reports/mo &mdash; starts on the same trial; upgrade anytime from your dashboard</span>
                    </span>
                </label>

                <label class="flex items-start gap-3 border-2 rounded-xl px-4 py-3 cursor-pointer transition-colors
                               has-[:checked]:border-orange-500 has-[:checked]:bg-orange-500/10 border-slate-700 bg-slate-900/40">
                    <input type="radio" name="plan" value="pro" required class="mt-1 accent-orange-500"
                           checked="@(selectedPlan == "pro" ? "checked" : null)" />
                    <span class="flex-1">
                        <span class="flex items-baseline justify-between">
                            <span class="text-white text-sm font-semibold">Pro <span class="text-orange-400 text-[10px] font-bold uppercase tracking-wide ml-1">Best Value</span></span>
                            <span class="text-slate-400 text-xs">$29.99 / month</span>
                        </span>
                        <span class="block text-slate-500 text-xs mt-0.5">75 PDF reports/mo &mdash; starts on the same trial; upgrade anytime from your dashboard</span>
                    </span>
                </label>
            </div>

            <input type="text" name="companyName" placeholder="Company name" value="@companyName"
                   class="w-full bg-slate-900/60 border border-slate-700 rounded-xl px-4 py-3 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-orange-500 transition" required />
            <input type="text" name="name" placeholder="Your name" value="@name"
                   class="w-full bg-slate-900/60 border border-slate-700 rounded-xl px-4 py-3 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-orange-500 transition" required />
            <input type="email" name="email" placeholder="Email" value="@email"
                   class="w-full bg-slate-900/60 border border-slate-700 rounded-xl px-4 py-3 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-orange-500 transition" required />
            <div class="relative">
                <input type="password" id="regPwd" name="password" placeholder="Password (min. 8 characters)"
                       class="w-full bg-slate-900/60 border border-slate-700 rounded-xl px-4 py-3 pr-11 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-orange-500 transition" required minlength="8" />
                <button type="button" onclick="togglePwd('regPwd', this)"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition">
                    <i class="fa-solid fa-eye text-sm"></i>
                </button>
            </div>
            <div class="relative">
                <input type="password" id="regPwdConfirm" name="confirmPassword" placeholder="Confirm password"
                       class="w-full bg-slate-900/60 border border-slate-700 rounded-xl px-4 py-3 pr-11 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-orange-500 transition" required minlength="8" />
                <button type="button" onclick="togglePwd('regPwdConfirm', this)"
                        class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition">
                    <i class="fa-solid fa-eye text-sm"></i>
                </button>
            </div>
            <button type="submit"
                    class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-xl px-4 py-3 text-sm transition">
                Create account
            </button>
        </form>

        <p class="text-center text-slate-400 text-xs mt-5">
            Already have an account?
            <a href="/Auth/Login?returnUrl=@Uri.EscapeDataString(returnUrl)" class="text-orange-400 hover:text-orange-300 font-medium">Sign in</a>
        </p>

    </div>

    <p class="text-center text-slate-600 text-xs mt-6">
        StormLead Pro &copy; 2026 &mdash; Your data is private and secure
    </p>

</div>
<script>
    function togglePwd(id, btn) {
        var el = document.getElementById(id);
        var icon = btn.querySelector('i');
        if (el.type === 'password') {
            el.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            el.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }
</script>
</body>
</html>
